# --- BACKEND SETTINGS ---
PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/talentflow
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRE=30d

# Cloudinary (Sign up at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail with App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Frontend URL (For CORS protection)
FRONTEND_URL=https://your-app-name.vercel.app

# --- FRONTEND SETTINGS ---
# Set this to your backend API URL if hosted separately, 
# or keep blank if using the unified Vercel deployment (routes will handle it).
VITE_API_URL=/api
